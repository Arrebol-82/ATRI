// 1. 告诉 Prisma 生成 JS/TS 客户端代码
generator client {
  provider = "prisma-client-js"
}

// 2. 告诉 Prisma 连接到你的 Supabase (PostgreSQL)
datasource db {
  provider = "postgresql"
}


// 下面是你之前写的模型，保持不动即可
model Merchandise {
  id               String   @id @default(cuid())
  name             String
  category         String
  priceDisplay     String
  imageDescription String
  imageUrl         String
  createdAt        DateTime @default(now())
  sortOrder        Int      @default(0) 
}